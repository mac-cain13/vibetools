<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Vibe Board is intentionally NOT sandboxed: it reads the ticket store under
	  /Volumes, watches it with FSEvents, and shells out to `git` for context —
	  all of which the App Sandbox would block. Local (UserNotifications)
	  notifications need no dedicated entitlement; they only require a signed
	  bundle with a CFBundleIdentifier (see build-app.sh). This file is passed to
	  codesign to make the non-sandboxed posture explicit.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
